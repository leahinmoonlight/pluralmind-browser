{
    "name": "pluralmind",
    "description": "Plurality support for Twitch Chat",
    "private": true,
    "version": "1.3.2",
    "type": "module",
    "license": "GPL-3.0-only",
    "author": "leahinmoonlight",
    "scripts": {
        "dev:chrome": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build:chrome": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip:chrome": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "zip": "pnpm zip:chrome && pnpm zip:firefox",
        "compile": "tsc --noEmit",
        "postinstall": "wxt prepare"
    },
    "devEngines": {
        "packageManager": {
            "name": "pnpm",
            "version": "^11.6.0",
            "onFail": "download"
        }
    },
    "dependencies": {
        "@types/lodash-es": "^4.17.12",
        "@webext-core/messaging": "^3.0.2",
        "@webext-core/proxy-service": "^2.0.1",
        "lodash-es": "^4.18.1",
        "pluralmind": "^1.2.1",
        "vue": "^3.5.39"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.1",
        "@vue/language-plugin-pug": "^3.3.5",
        "@wxt-dev/module-vue": "^1.0.3",
        "daisyui": "^5.6.3",
        "pug": "^3.0.4",
        "tailwindcss": "^4.3.1",
        "typescript": "^5.9.3",
        "vue-tsc": "^3.3.5",
        "wxt": "^0.20.26"
    }
}
