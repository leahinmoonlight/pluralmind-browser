{
    "name": "pluralmind",
    "description": "Plurality support for Twitch Chat",
    "private": true,
    "version": "1.2.1",
    "type": "module",
    "license": "GPL-3.0-only",
    "author": "leahinmoonlight",
    "scripts": {
        "dev:chrome": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build:chrome": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip:chrome": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "zip": "pnpm zip:chrome && pnpm zip:firefox",
        "compile": "tsc --noEmit",
        "postinstall": "wxt prepare"
    },
    "devEngines": {
        "packageManager": {
            "name": "pnpm",
            "version": "^11.6.0",
            "onFail": "download"
        }
    },
    "dependencies": {
        "@webext-core/messaging": "^3.0.2",
        "@webext-core/proxy-service": "^2.0.1",
        "pluralmind": "^1.0.1"
    },
    "devDependencies": {
        "typescript": "^5.9.3",
        "wxt": "^0.20.26"
    }
}
